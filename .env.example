# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Admin console
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password
ADMIN_SESSION_SECRET=at-least-32-random-characters-here
ADMIN_TOTP_SECRET=your-base32-totp-secret

# Cloudflare Turnstile (https://dash.cloudflare.com)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# Resend email (https://resend.com)
# Currently sends from info@accountingbody.com (verified domain)
# Update FROM_ADDRESS in lib/email.ts once hagerland.com is verified on Resend
RESEND_API_KEY=re_your_key_here
